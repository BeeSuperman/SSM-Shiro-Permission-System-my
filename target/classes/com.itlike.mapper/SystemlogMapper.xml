<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.itlike.mapper.SystemlogMapper">

  <resultMap id="BaseResultMap" type="com.itlike.domain.Systemlog">
    <id column="id" property="id" />
    <result column="optime" property="optime" />
    <result column="ip" property="ip" />
    <result column="function" property="function" />
    <result column="params" property="params" />
  </resultMap>

  <insert id="insert" parameterType="com.itlike.domain.Systemlog">
    insert into systemlog (id, optime, ip, `function`, params)
    values (#{id}, #{optime}, #{ip}, #{function}, #{params})
  </insert>

  <select id="selectByPrimaryKey" resultMap="BaseResultMap">
    select id, optime, ip, `function`, params from systemlog where id = #{id}
  </select>

  <select id="selectAll" resultMap="BaseResultMap">
    select id, optime, ip, `function`, params from systemlog
  </select>
</mapper>